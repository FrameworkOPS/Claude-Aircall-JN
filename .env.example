# ─── Aircall ───────────────────────────────────────────────────────────────
# Basic Auth credentials from the Aircall Dashboard (Integrations > API Keys).
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
# Base URL for the Aircall REST API (rarely changed).
AIRCALL_BASE_URL=https://api.aircall.io/v1
# The per-webhook token Aircall shows when you create the webhook. Required.
AIRCALL_WEBHOOK_SECRET=
# Verify the X-Aircall-Signature HMAC-SHA1 header in addition to the body token.
AIRCALL_VERIFY_HMAC=false
# Aircall REST rate limit (requests/minute) — token bucket. Docs: ~60/min.
AIRCALL_RATE_LIMIT_PER_MIN=60

# Minutes (comma separated) to wait/retry for a recording to become available
# after call.ended before giving up.
RECORDING_POLL_SCHEDULE_MIN=1,3,5,10

# ─── JobNimbus ─────────────────────────────────────────────────────────────
# API key from JobNimbus: Settings > API.
JOBNIMBUS_API_KEY=
JOBNIMBUS_BASE_URL=https://app.jobnimbus.com/api1
# Shared secret you configure on the JobNimbus automation/webhook -> our endpoint.
JOBNIMBUS_WEBHOOK_SECRET=
JOBNIMBUS_RATE_LIMIT_PER_MIN=100
# Signature statuses that count as "fully signed" (comma separated, lowercased).
ESTIMATE_SIGNED_STATUSES=signed,complete,completed
# Where call notes/recordings attach: 'job' (related job, fallback contact),
# 'contact', or 'both'.
ATTACH_TARGET=job

# ─── Slack (estimate-signed shoutout) ──────────────────────────────────────
# Bot token (xoxb-...) with chat:write for the CLIENT workspace.
SLACK_BOT_TOKEN=
# Channel ID (e.g. C0123ABC) to post sales shoutouts into.
SLACK_CHANNEL_ID=

# ─── Phone normalization ───────────────────────────────────────────────────
DEFAULT_PHONE_REGION=US

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/aircall_jobnimbus
# Set to 'require' for managed Postgres (Railway) that needs TLS.
DATABASE_SSL=disable

# ─── Behaviour flags ───────────────────────────────────────────────────────
CREATE_CONTACT_FROM_CALL=false
ENABLE_MERGE_ENDPOINT=false
MAX_RETRIES=6

# ─── Runtime ───────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Run the worker loop inside the web process (true) or as a separate service (false).
RUN_WORKER_IN_WEB=true
# Worker poll interval in milliseconds.
WORKER_POLL_INTERVAL_MS=2000
